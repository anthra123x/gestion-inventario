generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                 String              @id @default(cuid())
  email              String              @unique
  name               String
  role               UserRole            @default(EMPLOYEE)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  inventoryMovements InventoryMovement[]
  repairs            Repair[]
  sales              Sale[]

  @@map("users")
}

model Client {
  id        String    @id @default(cuid())
  name      String
  phone     String    @unique
  email     String?
  address   String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  repairs   Repair[]
  sales     Sale[]

  @@index([phone])
  @@index([name])
  @@index([deletedAt])
  @@map("clients")
}

model Product {
  id                 String              @id @default(cuid())
  name               String
  description        String?
  category           ProductCategory
  stock              Int                 @default(0)
  minStock           Int                 @default(5)
  purchasePrice      Float               @default(0)
  salePrice          Float               @default(0)
  supplier           String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  deletedAt          DateTime?
  inventoryMovements InventoryMovement[]
  orderItems         OrderItem[]
  repairParts        RepairPart[]
  saleItems          SaleItem[]
  ecommerce          EcommerceProduct?

  @@index([category])
  @@index([stock])
  @@index([name])
  @@index([supplier])
  @@index([deletedAt])
  @@map("products")
}

model EcommerceProduct {
  id               String           @id @default(cuid())
  productId        String           @unique @map("product_id")
  product          Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  ecommercePrice   Float?           @map("ecommerce_price")
  compareAtPrice   Float?           @map("compare_at_price")
  visible          Boolean          @default(true)
  featured         Boolean          @default(false)
  publishedAt      DateTime?        @map("published_at")
  slug             String?          @unique
  metaTitle        String?          @map("meta_title")
  metaDescription  String?          @map("meta_description")
  shortDescription String?          @map("short_description")
  longDescription  String?          @map("long_description")
  badges           String[]
  tags             String[]
  sortOrder        Int              @default(0) @map("sort_order")
  showStock        Boolean          @default(true) @map("show_stock")
  media            ProductMedia[]
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  @@index([visible])
  @@index([featured])
  @@index([sortOrder])
  @@index([publishedAt])
  @@map("product_ecommerce")
}

model ProductMedia {
  id              String           @id @default(cuid())
  ecommerceId     String           @map("ecommerce_id")
  ecommerce       EcommerceProduct @relation(fields: [ecommerceId], references: [id], onDelete: Cascade)
  url             String
  alt             String?
  width           Int?
  height          Int?
  sortOrder       Int              @default(0) @map("sort_order")
  isPrimary       Boolean          @default(false) @map("is_primary")
  storageProvider String           @default("placeholder") @map("storage_provider")
  storageId       String?          @map("storage_id")
  createdAt       DateTime         @default(now()) @map("created_at")

  @@index([ecommerceId])
  @@index([isPrimary])
  @@map("product_media")
}

model Sale {
  id              String        @id @default(cuid())
  clientId        String?
  total           Float
  paymentMethod   PaymentMethod
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  userId          String?
  clientAddress   String?
  clientEmail     String?
  clientName      String?
  clientPhone     String?
  discountAmount  Float         @default(0)
  discountPercent Float         @default(0)
  saleItems       SaleItem[]
  client          Client?       @relation(fields: [clientId], references: [id])
  user            User?         @relation(fields: [userId], references: [id])

  @@index([clientId])
  @@index([createdAt])
  @@index([paymentMethod])
  @@map("sales")
}

model SaleItem {
  id                  String  @id @default(cuid())
  saleId              String
  productId           String
  quantity            Int
  unitPrice           Float
  total               Float
  profit              Float   @default(0)
  purchasePriceAtSale Float   @default(0)
  product             Product @relation(fields: [productId], references: [id])
  sale                Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([saleId])
  @@map("sale_items")
}

model Repair {
  id            String       @id @default(cuid())
  clientId      String
  device        String
  problem       String
  diagnosis     String?
  status        RepairStatus @default(RECEIVED)
  cost          Float        @default(0)
  notes         String?
  internalNotes String?
  dateReceived  DateTime     @default(now())
  dateDelivered DateTime?
  estimatedDate DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  userId        String?
  partsCost     Float        @default(0)
  profit        Float        @default(0)
  repairParts   RepairPart[]
  client        Client       @relation(fields: [clientId], references: [id])
  user          User?        @relation(fields: [userId], references: [id])

  @@index([clientId])
  @@index([status])
  @@index([createdAt])
  @@map("repairs")
}

model RepairPart {
  id                  String  @id @default(cuid())
  repairId            String
  productId           String
  quantity            Int
  unitCost            Float
  total               Float
  purchasePriceAtPart Float   @default(0)
  product             Product @relation(fields: [productId], references: [id])
  repair              Repair  @relation(fields: [repairId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([repairId])
  @@map("repair_parts")
}

model InventoryMovement {
  id            String       @id @default(cuid())
  productId     String
  type          MovementType
  quantity      Int
  reason        String?
  referenceId   String?
  referenceType String?
  createdAt     DateTime     @default(now())
  userId        String?
  product       Product      @relation(fields: [productId], references: [id])
  user          User?        @relation(fields: [userId], references: [id])

  @@index([productId])
  @@index([createdAt])
  @@map("inventory_movements")
}

model SystemSettings {
  id              String   @id @default(cuid())
  companyName     String   @default("Tecnicell")
  companyAddress  String?
  companyPhone    String?
  companyEmail    String?
  defaultMinStock Int      @default(5)
  lowStockAlert   Boolean  @default(true)
  currency        String   @default("COP")
  taxRate         Float    @default(0)
  receiptFooter   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("system_settings")
}

model Order {
  id                 String      @id @default(cuid())
  clientName         String
  clientPhone        String
  clientCity         String?
  clientEmail        String?
  clientAddress      String?
  clientNotes        String?
  status             OrderStatus @default(PENDING)
  subtotal           Float       @default(0)
  shipping           Float       @default(0)
  total              Float       @default(0)
  externalReference  String?     @unique
  internalNotes      String?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  items              OrderItem[]

  @@index([status])
  @@index([createdAt])
  @@index([clientPhone])
  @@index([externalReference])
  @@map("orders")
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  unitPrice Float
  total     Float
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

enum UserRole {
  ADMIN
  EMPLOYEE
}

enum ProductCategory {
  ACCESSORY
  REPAIR_PART
  DEVICE
  OTHER
}

enum RepairStatus {
  RECEIVED
  IN_PROGRESS
  READY
  DELIVERED
  CANCELLED
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
}

enum MovementType {
  ENTRY
  EXIT
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  SHIPPED
  DELIVERED
  CANCELLED
}
