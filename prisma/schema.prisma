generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String  @id @default(cuid())
  email     String  @unique
  name      String
  role      UserRole @default(EMPLOYEE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  repairs   Repair[]

  @@map("users")
}

model Client {
  id        String    @id @default(cuid())
  name      String
  phone     String?
  email     String?
  address   String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  repairs   Repair[]

  @@index([phone])
  @@index([name])
  @@index([deletedAt])
  @@map("clients")
}

model Part {
  id          String    @id @default(cuid())
  name        String
  description String?
  supplier    String?
  price       Float     @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  repairParts RepairPart[]

  @@index([name])
  @@index([deletedAt])
  @@map("parts")
}

model Repair {
  id            String       @id @default(cuid())
  clientId      String
  device        String
  problem       String
  diagnosis     String?
  status        RepairStatus @default(RECEIVED)
  laborCost     Float        @default(0)
  notes         String?
  internalNotes String?
  dateReceived  DateTime     @default(now())
  dateDelivered DateTime?
  estimatedDate DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  userId        String?
  repairParts   RepairPart[]
  client        Client       @relation(fields: [clientId], references: [id])
  user          User?        @relation(fields: [userId], references: [id])

  @@index([clientId])
  @@index([clientId, createdAt])
  @@index([status])
  @@index([createdAt])
  @@index([status, createdAt])
  @@map("repairs")
}

model RepairPart {
  id        String @id @default(cuid())
  repairId  String
  partId    String
  quantity  Int
  unitCost  Float
  total     Float
  part      Part   @relation(fields: [partId], references: [id])
  repair    Repair @relation(fields: [repairId], references: [id], onDelete: Cascade)

  @@index([partId])
  @@index([repairId])
  @@map("repair_parts")
}

model SystemSettings {
  id              String   @id @default(cuid())
  companyName     String   @default("Gestión Reparaciones")
  companyAddress  String?
  companyPhone    String?
  companyEmail    String?
  currency        String   @default("COP")
  receiptTitle    String   @default("FICHA TÉCNICA")
  receiptTagline  String?  @default("Centro de Servicio Técnico")
  receiptFooter   String?
  warrantyText    String   @default("Este servicio técnico cuenta con una garantía de 30 días en mano de obra a partir de la fecha de entrega. Los repuestos instalados cubren la garantía otorgada por el fabricante. La garantía no cubre daños por mal uso, golpes, humedad o manipulación por terceros no autorizados.")
  invoicePrefix   String   @default("REP-")
  defaultWarrantyDays Int  @default(30)
  lowStockThreshold    Int  @default(5)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("system_settings")
}

model Notification {
  id         String           @id @default(cuid())
  userId     String?
  type       NotificationType
  title      String
  message    String?
  entityType String?
  entityId   String?
  read       Boolean          @default(false)
  createdAt  DateTime         @default(now())

  @@index([userId, read])
  @@index([userId, createdAt])
  @@index([entityType, entityId])
  @@map("notifications")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  details   String?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([entity, entityId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

enum UserRole {
  ADMIN
  EMPLOYEE
}

enum RepairStatus {
  RECEIVED
  IN_PROGRESS
  READY
  DELIVERED
  CANCELLED
}

enum NotificationType {
  REPAIR_READY
  SYSTEM
  WEEK_CLOSED
  SAVING_GOAL_REACHED
  LOW_STOCK
  BUDGET_ALERT
}

enum CategoryType {
  INCOME
  EXPENSE
  SAVING_GOAL
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum BudgetPeriodStatus {
  ACTIVE
  CLOSED
}

model Category {
  id        String        @id @default(cuid())
  name      String
  type      CategoryType
  color     String?
  icon      String?
  budget    Float?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  deletedAt DateTime?
  transactions Transaction[]
  savingGoals  SavingGoal[]

  @@index([type])
  @@index([deletedAt])
  @@map("categories")
}

model BudgetPeriod {
  id               String              @id @default(cuid())
  startDate        DateTime
  endDate          DateTime
  status           BudgetPeriodStatus  @default(ACTIVE)
  initialBalance   Float               @default(0)
  savingsAllocated Float               @default(0)
  notes            String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  transactions     Transaction[]

  @@index([status])
  @@index([startDate, endDate])
  @@map("budget_periods")
}

model Transaction {
  id           String          @id @default(cuid())
  type         TransactionType
  amount       Float
  description  String
  date         DateTime        @default(now())
  categoryId   String
  category     Category        @relation(fields: [categoryId], references: [id])
  periodId     String?
  period       BudgetPeriod?   @relation(fields: [periodId], references: [id])
  isRecurring  Boolean         @default(false)
  recurringDay Int?
  notes        String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([date])
  @@index([type])
  @@index([categoryId])
  @@index([periodId])
  @@index([isRecurring])
  @@map("transactions")
}

model SavingGoal {
  id            String    @id @default(cuid())
  name          String
  targetAmount  Float
  currentAmount Float     @default(0)
  deadline      DateTime?
  categoryId    String?
  category      Category? @relation(fields: [categoryId], references: [id])
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("saving_goals")
}
